# .env.example

# App
APP_SECRET_KEY=generate-with-python-secrets-token-hex-32
APP_ENV=development                    # development | production

# Database
DATABASE_URL=postgresql+asyncpg://career_os:password@localhost:5432/career_os_db

# GitHub
GITHUB_PAT=ghp_your_personal_access_token
GITHUB_USERNAME=your-github-username

# Indeed API
INDEED_API_KEY=your_indeed_publisher_key
INDEED_PUBLISHER_ID=your_publisher_id

# Gemini
GEMINI_API_KEY=AIza_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro-preview-05-06

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_password
N8N_WEBHOOK_URL=http://localhost:5678

# LinkedIn (no OAuth — uses data export)
LINKEDIN_EXPORT_WEBHOOK_SECRET=generate-random-string

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=Career OS

# API Auth (optional — leave empty to disable auth in dev)
API_AUTH_KEY=
VITE_API_KEY=
